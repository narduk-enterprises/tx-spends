@narduk-enterprises:registry=https://npm.pkg.github.com
; Auth: the //npm.pkg.github.com/:_authToken line is intentionally NOT set here.
; For local dev, ensure ~/.npmrc contains the GitHub Packages token (see AGENTS.md).
; For CI: set GITHUB_TOKEN_PACKAGES_READ in the Doppler project and pass via:
;   doppler run -- pnpm install
; Or set NODE_AUTH_TOKEN as a CI env var and add:
;   //npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
