{
  "name": "web",
  "type": "module",
  "private": true,
  "version": "1.17.2",
  "scripts": {
    "build": "nuxt build",
    "dev": "doppler run --config dev -- sh -c 'CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=\"$DATABASE_URL\" nuxt dev'",
    "quality": "echo 'Turbo dependsOn handles lint + typecheck + format:check'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "doppler run --config dev -- drizzle-kit migrate",
    "db:studio": "doppler run --config dev -- drizzle-kit studio",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "deploy": "wrangler deploy --env=\"\"",
    "prelint": "test -f .nuxt/eslint.config.mjs || nuxt prepare",
    "lint": "eslint . --max-warnings 0",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --project=web --config=../../playwright.config.ts",
    "test:e2e:visual": "playwright test tests/e2e/visual-audit.spec.ts --project=web --config=../../playwright.config.ts",
    "test:unit": "vitest run",
    "format:check": "prettier --check \"**/*.{ts,mts,vue,js,mjs,json,yaml,yml,css,md}\" --ignore-path ../../.gitignore"
  },
  "dependencies": {
    "@narduk-enterprises/eslint-config": "^1.0.17",
    "@narduk-enterprises/narduk-nuxt-template-layer": "workspace:*",
    "@neondatabase/serverless": "^1.0.0",
    "d3-geo": "^3.1.1",
    "drizzle-orm": "^0.45.1",
    "nuxt": "^4.3.1",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250303.0",
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/lucide": "^1.2.94",
    "@tailwindcss/vite": "^4.0.0",
    "@types/d3-geo": "^3.1.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "nitro-cloudflare-dev": "^0.2.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.20.0"
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@7.3.1"
  },
  "volta": {
    "node": "22.22.0"
  }
}
